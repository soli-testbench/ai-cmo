{
  "name": "@chief-mog/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@chief-mog/config": "*",
    "@chief-mog/types": "*",
    "drizzle-orm": "0.45.1",
    "postgres": "3.4.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "typescript": "~5.7.0",
    "vitest": "4.1.1"
  }
}
