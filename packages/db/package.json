{
  "name": "@chief-mog/db",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "@chief-mog/types": "*",
    "@chief-mog/config": "*",
    "@chief-mog/lib": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "drizzle-kit": "^0.31.10",
    "typescript": "~5.7.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.1"
  }
}
