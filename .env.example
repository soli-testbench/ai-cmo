# IMPORTANT: These defaults are for local development ONLY.
# For production, override DATABASE_URL with strong credentials and set JWT_SECRET.
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chief_mog
REDIS_URL=redis://localhost:6379
API_PORT=3001
WEB_PORT=3000
WORKER_CONCURRENCY=5
LOG_LEVEL=debug

# JWT auth — required in production; random per-instance secret used in dev if unset
# Generate with: openssl rand -hex 32
# JWT_SECRET=<your-strong-random-secret>
# JWT_ISSUER=chief-mog
# JWT_AUDIENCE=chief-mog-api

# CORS — defaults to * in development; set explicitly for production
# CORS_ORIGIN=https://your-domain.com
